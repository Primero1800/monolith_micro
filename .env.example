APP_NAME=test_monolith
APP_VERSION=0.1.0

POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=test_monolith_db

POOL_SIZE=10
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=1800

LOG_LEVEL=DEBUG

AIOHTTP_KEEPALIVE_TIMEOUT=30
AIOHTTP_TIMEOUT_SECONDS=30

HEALTH_CHECK_TIMEOUT_SEC=5

# Универсальный AI-клиент — любой OpenAI-совместимый провайдер (одинаковый wire-формат chat/completions).
# Модели проверены на актуальность на 2026-07-16 (кроме OpenAI — см. пометку ниже), но провайдеры
# переименовывают/депрекейтят модели чаще, чем раз в полгода — если пресет не подошёл, проверь
# актуальный список моделей в документации провайдера.
#
# Mistral:  https://api.mistral.ai/v1     модели: mistral-small-latest, mistral-large-latest
#           ("-latest" — алиас, всегда указывает на актуальную версию, не протухает)
# DeepSeek: https://api.deepseek.com/v1   модели: deepseek-v4-flash, deepseek-v4-pro
#           (старые deepseek-chat/deepseek-reasoner депрекейтятся 2026-07-24 — не использовать)
# OpenAI:   https://api.openai.com/v1     модель: уточни на platform.openai.com/docs/models —
#           gpt-4o/gpt-4o-mini уже сняты с эксплуатации (линейка на 2026-07 — GPT-5.6), точную
#           строку для API лучше свериться самому, чем полагаться на пресет здесь
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_API_KEY=your_key_here
LLM_MODEL=mistral-small-latest

LLM_TIMEOUT_SEC=30
